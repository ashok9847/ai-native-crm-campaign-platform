# Backend environment variables
# Copy to .env and fill in real values before running

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string — use asyncpg dialect for the app.
# Supabase example: postgresql+asyncpg://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/nudge

# ── AI / Nebius ───────────────────────────────────────────
NEBIUS_API_KEY=your-nebius-api-key-here
NEBIUS_BASE_URL=https://api.tokenfactory.us-central1.nebius.com/v1/
KIMI_MODEL=moonshotai/Kimi-K2.5-fast

# ── Channel service ───────────────────────────────────────
CHANNEL_SERVICE_URL=http://localhost:8001
# Shared secret — must match CHANNEL_WEBHOOK_SECRET in channel-service/.env
CHANNEL_WEBHOOK_SECRET=change-me-to-a-random-secret

# ── Backend public URL (used as callback base in dispatch requests) ────
BACKEND_URL=http://localhost:8000

# ── Campaign behaviour ────────────────────────────────────
# Seconds a campaign may stay in EXECUTING before being flagged as stalled
CAMPAIGN_STALL_TIMEOUT_SECONDS=300
