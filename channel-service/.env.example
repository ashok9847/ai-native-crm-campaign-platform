# Channel service environment variables
# Copy to .env and fill in real values before running

# ── Authentication ────────────────────────────────────────
# Must match CHANNEL_WEBHOOK_SECRET in backend/.env
CHANNEL_WEBHOOK_SECRET=change-me-to-a-random-secret

# ── CRM callback target ───────────────────────────────────
# Not needed at startup — provided per-dispatch in the request body.
# Kept here for local override / testing convenience.
CRM_CALLBACK_URL=http://localhost:8000/api/v1/campaigns/callback

# ── Delivery simulation timing (milliseconds) ─────────────
CALLBACK_MIN_DELAY_MS=1000
CALLBACK_MAX_DELAY_MS=5000

# ── Delivery simulation drop-off rates (0.0 – 1.0) ───────
DELIVERY_RATE=0.95
OPEN_RATE=0.60
CLICK_RATE=0.30
FAILURE_RATE=0.10
